generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Workout {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())

  @@map("workouts")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  authId    String   @unique
  email     String
  name      String?
  role      String
  createdAt DateTime @default(now())

  bodyMeasurements BodyMeasurement[]
  workoutTypes     WorkoutType[]

  @@map("users")
}

model BodyMeasurement {
  id         Int      @id @default(autoincrement())
  chest      Int?
  waist      Int?
  hips       Int?
  leftArm    Int?
  rightArm   Int?
  leftThigh  Int?
  rightThigh Int?
  leftCalf   Int?
  rightCalf  Int?
  createdAt  DateTime @default(now())

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  @@map("body_measurements")
}

model WorkoutType {
  id          String   @id @default(uuid())
  name        String
  description String
  status      Boolean
  createdAt   DateTime @default(now())
  userId String       @db.Uuid

  plans  WorkoutPlan[]
  user   User?        @relation(fields: [userId], references: [id])
  
  @@map("workout_types")
}

model WorkoutPlan {
  id        String   @id @default(uuid())
  name      String
  status    Boolean
  createdAt DateTime @default(now())

  workoutTypeId String
  workoutType   WorkoutType @relation(fields: [workoutTypeId], references: [id], onDelete: Cascade)

  plansExercises  WorkoutPlanExercise[]

  @@map("workout_plans")
}


model WorkoutPlanExercise {
  id              String   @id @default(uuid())
  workoutPlanId   String
  exerciseId      String

  workoutPlan    WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercise       Exercise @relation(fields: [exerciseId], references: [id]) 

  exerciseSet  ExerciseSet[]
  @@map("workout_plans_exercises")
}

model ExerciseType {
  id   String @id @default(uuid())
  name String

  exercises Exercise[]

  @@map("exercise_types")
}

model Exercise {
  id        String   @id @default(uuid())
  name      String
  status    Boolean
  createdAt DateTime @default(now())
  
  exerciseTypeId       String
  exerciseType         ExerciseType          @relation(fields: [exerciseTypeId], references: [id])
  plansExercises  WorkoutPlanExercise[]

  @@map("exercises")
}

model ExerciseSet {
  id                        String @id @default(uuid())
  workoutPlanExerciseId     String
  sets                      Int
  weight                    Float
  reps                      Int
  rest                      Int
  muscle                    String
  order                     Int

  createdAt DateTime @default(now())

  workoutPlanExercise    WorkoutPlanExercise @relation(fields: [workoutPlanExerciseId], references: [id], onDelete: Cascade)
  @@map("exercise_sets")
}
